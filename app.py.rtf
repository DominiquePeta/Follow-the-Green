# RISK MANAGEMENT HELPER\
# \uc0\u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
\
\
def calculate_position_size(\
    price_pence: float,\
    risk_gbp: float = 750.0,\
    stop_loss_pct: float = 0.10,\
) -> dict:\
    """\
    Felix's 1% Rule Position Sizing.\
\
    The core principle:\
        "Never risk more than 1% of your account on any single trade."\
\
    Here we use a fixed \'a3750 risk amount (user's "1% of portfolio").\
    The stop loss is set at X% below the entry price.\
\
    Formula:\
        Risk per share (\'a3) = Entry price (\'a3) \'d7 Stop loss %\
        Max shares         = Total risk (\'a3) / Risk per share (\'a3)\
        Position value (\'a3) = Max shares \'d7 Entry price (\'a3)\
\
    Example at 10% stop:\
        Stock at 500p = \'a35.00\
        Risk per share = \'a35.00 \'d7 10% = \'a30.50\
        Max shares = \'a3750 / \'a30.50 = 1,500 shares\
        Position value = 1,500 \'d7 \'a35.00 = \'a37,500\
\
    If the stock drops 10% \uc0\u8594  you lose exactly \'a3750 (your 1% rule limit).\
    This keeps any single loss from materially damaging your portfolio.\
    """\
    price_gbp = price_pence / 100.0           # Convert pence \uc0\u8594  pounds\
    risk_per_share = price_gbp * stop_loss_pct\
    num_shares = risk_gbp / risk_per_share\
    position_value = num_shares * price_gbp\
    stop_price_pence = price_pence * (1.0 - stop_loss_pct)\
    potential_reward = position_value * (stop_loss_pct * 2)  # Assumes 2:1 reward/risk\
\
    return \{\
        "Entry Price": f"\{price_pence:.2f\}p  (\'a3\{price_gbp:.2f\})",\
        "Stop Loss Price": f"\{stop_price_pence:.2f\}p  (\'a3\{stop_price_pence/100:.2f\})",\
        "Stop Loss %": f"\{stop_loss_pct * 100:.0f\}% below entry",\
        "Max Shares to Buy": f"\{int(num_shares):,\} shares",\
        "Max Position Value": f"\'a3\{position_value:,.0f\}",\
        "Max Risk (\'a3)": f"\'a3\{risk_gbp:,.0f\}",\
        "Target Reward (2:1)": f"\'a3\{potential_reward:,.0f\}",\
    \}\
\
\
