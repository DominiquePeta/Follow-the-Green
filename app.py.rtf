\
\
def calculate_indicators(df: pd.DataFrame) -> pd.DataFrame:\
    """\
    Calculate all technical indicators used in Felix's "Follow the Green" method.\
\
    \uc0\u9484 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9488 \
    \uc0\u9474   INDICATOR 1 \'97 SMA50 (50-Day Simple Moving Average)                    \u9474 \
    \uc0\u9474   Felix uses the 50 SMA as the primary TREND FILTER.                    \u9474 \
    \uc0\u9474   \u8594  Price ABOVE SMA50 = uptrend  \u8594  only consider long trades here       \u9474 \
    \uc0\u9474   \u8594  Price BELOW SMA50 = downtrend \u8594  stay out or expect more weakness    \u9474 \
    \uc0\u9474   Why SMA50? It smooths out short-term noise while still being          \u9474 \
    \uc0\u9474   responsive enough to catch medium-term trend changes.                 \u9474 \
    \uc0\u9500 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9508 \
    \uc0\u9474   INDICATOR 2 \'97 Vol_MA20 (20-Day Average Volume)                        \u9474 \
    \uc0\u9474   Establishes the "normal" level of trading activity.                   \u9474 \
    \uc0\u9474   A self-adjusting baseline \'97 if a stock naturally trades more in       \u9474 \
    \uc0\u9474   summer, the average adjusts, so spikes are always meaningful.         \u9474 \
    \uc0\u9500 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9508 \
    \uc0\u9474   INDICATOR 3 \'97 Vol_Ratio (Today's Volume / 20-Day Average)             \u9474 \
    \uc0\u9474   This is the KEY signal metric. A ratio > 1.5 means volume is         \u9474 \
    \uc0\u9474   50% above normal \'97 clear sign of unusual institutional participation. \u9474 \
    \uc0\u9474   Felix's threshold: 1.5\'d7 minimum; ideally 2\'d7+ for strongest signals.  \u9474 \
    \uc0\u9500 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9508 \
    \uc0\u9474   INDICATOR 4 \'97 Vol_5d_Trend (Is volume rising over 5 days?)           \u9474 \
    \uc0\u9474   A single volume spike can be noise (ex-dividend date, index           \u9474 \
    \uc0\u9474   rebalancing, one large trade). A 5-day rising trend = sustained       \u9474 \
    \uc0\u9474   accumulation by institutions loading a position over multiple days.   \u9474 \
    \uc0\u9492 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9496 \
    """\
    df = df.copy()\
\
    # \uc0\u9472 \u9472  SMA50: 50-day Simple Moving Average on Close price \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    df["SMA50"] = df["Close"].rolling(window=50, min_periods=50).mean()\
\
    # \uc0\u9472 \u9472  Vol_MA20: 20-day rolling average volume \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    df["Vol_MA20"] = df["Volume"].rolling(window=20, min_periods=20).mean()\
\
    # \uc0\u9472 \u9472  Vol_Ratio: current volume relative to the 20-day average \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Guard against division by zero on days with no volume data\
    df["Vol_Ratio"] = df["Volume"] / df["Vol_MA20"].replace(0, float("nan"))\
\
    # \uc0\u9472 \u9472  Vol_5d_Trend: is volume higher at day 5 than day 1? \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Simple but effective: compares the last day vs the first day of the window.\
    # Returns 1.0 if trend is up, 0.0 if flat or down.\
    df["Vol_5d_Trend"] = (\
        df["Volume"]\
        .rolling(window=5, min_periods=5)\
        .apply(lambda x: 1.0 if float(x.iloc[-1]) > float(x.iloc[0]) else 0.0, raw=False)\
    )\
\
    # \uc0\u9472 \u9472  Dist_SMA50_Pct: % distance of price from the 50 SMA \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Useful for finding stocks near their SMA50 (potential breakout/breakdown)\
    # vs stocks already extended far above/below (higher risk).\
    df["Dist_SMA50_Pct"] = ((df["Close"] - df["SMA50"]) / df["SMA50"]) * 100\
\
    return df\
\
\
# \uc0\u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
# BIG MONEY SIGNAL DETECTION\
# \uc0\u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
\
\
def detect_signals(df: pd.DataFrame) -> pd.DataFrame:\
    """\
    Detect Bullish Accumulation and Bearish Distribution signals.\
\
    \uc0\u9484 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9488 \
    \uc0\u9474   SIGNAL 1 \'97 BULLISH ACCUMULATION (\u55357 \u57314 )                                  \u9474 \
    \uc0\u9474                                                                          \u9474 \
    \uc0\u9474   Condition:                                                             \u9474 \
    \uc0\u9474     Close > SMA50           (Price is in an uptrend)                    \u9474 \
    \uc0\u9474     AND Vol_Ratio > 1.5     (Volume is spiking \'97 institutions buying)   \u9474 \
    \uc0\u9474     AND Vol_5d_Trend = 1    (Volume has been rising for 5 days)         \u9474 \
    \uc0\u9474                                                                          \u9474 \
    \uc0\u9474   Why this = Felix's "accumulation":                                     \u9474 \
    \uc0\u9474     Institutions cannot buy millions of shares in one day without        \u9474 \
    \uc0\u9474     crashing the price. They spread their buying over many sessions.     \u9474 \
    \uc0\u9474     A 5-day rising volume trend + above-average volume = they are        \u9474 \
    \uc0\u9474     LOADING UP. The fact that price is above SMA50 confirms the trend   \u9474 \
    \uc0\u9474     is supporting their conviction. This is the "green" to follow.      \u9474 \
    \uc0\u9500 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9508 \
    \uc0\u9474   SIGNAL 2 \'97 BEARISH DISTRIBUTION (\u55357 \u56628 )                                  \u9474 \
    \uc0\u9474                                                                          \u9474 \
    \uc0\u9474   Condition:                                                             \u9474 \
    \uc0\u9474     Close < SMA50           (Price is in a downtrend)                   \u9474 \
    \uc0\u9474     AND Vol_Ratio > 1.5     (Volume is spiking \'97 institutions selling)  \u9474 \
    \uc0\u9474                                                                          \u9474 \
    \uc0\u9474   Why this = Felix's "distribution":                                     \u9474 \
    \uc0\u9474     When smart money decides to EXIT a position, they sell into          \u9474 \
    \uc0\u9474     any remaining buying interest. The result: high volume on DOWN       \u9474 \
    \uc0\u9474     days below the trend line. Felix calls this "distribution" \'97        \u9474 \
    \uc0\u9474     institutions are handing shares to retail investors at peak          \u9474 \
    \uc0\u9474     prices before the real move down. STAY OUT of these stocks.         \u9474 \
    \uc0\u9492 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9496 \
    """\
    df = df.copy()\
\
    # Initialise signal columns\
    df["Signal"] = "Neutral"\
    df["Bullish"] = False\
    df["Bearish"] = False\
\
    # \uc0\u9472 \u9472  BULLISH ACCUMULATION: Three-part confirmation \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Felix's rule: all three conditions must be TRUE simultaneously.\
    # This triple-filter greatly reduces false signals.\
    bullish_mask = (\
        (df["Close"] > df["SMA50"])     # Uptrend confirmed\
        & (df["Vol_Ratio"] > 1.5)        # Volume spike: 50%+ above 20-day average\
        & (df["Vol_5d_Trend"] == 1.0)    # 5-day rising volume trend: sustained buying\
    )\
    df.loc[bullish_mask, "Signal"] = "Bullish Accumulation"\
    df.loc[bullish_mask, "Bullish"] = True\
\
    # \uc0\u9472 \u9472  BEARISH DISTRIBUTION: Two-part warning \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Simpler threshold \'97 price weakness + volume spike is enough for caution.\
    # We don't require a 5-day trend because a single large sell-off is warning enough.\
    bearish_mask = (\
        (df["Close"] < df["SMA50"])     # Downtrend: price below trend line\
        & (df["Vol_Ratio"] > 1.5)        # Volume spike: unusual selling pressure\
    )\
    df.loc[bearish_mask, "Signal"] = "Bearish Distribution"\
    df.loc[bearish_mask, "Bearish"] = True\
\
    # Note: A stock can't simultaneously be above and below SMA50,\
    # so bullish and bearish masks are always mutually exclusive.\
\
    return df\
\
\
