# MONEY FLOW SCORE (0\'96100)\
# \uc0\u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
\
\
def calculate_money_flow_score(row: pd.Series) -> int:\
    """\
    Composite score from 0 (very bearish) to 100 (very bullish).\
\
    Three components (mirroring Felix's mental checklist):\
\
    1. Trend Score (0\'9650 pts):\
       Where is the price relative to SMA50?\
       \uc0\u8594  Far above SMA50 \u8594  up to 50 pts\
       \uc0\u8594  At SMA50 \u8594  25 pts (neutral)\
       \uc0\u8594  Far below SMA50 \u8594  0 pts\
\
    2. Volume Score (0\'9635 pts):\
       How large is the volume spike?\
       \uc0\u8594  3\'d7 average = max 35 pts\
       \uc0\u8594  1.5\'d7 average = ~17 pts\
       \uc0\u8594  Average or below = 0 pts\
\
    3. Momentum Score (0\'9615 pts):\
       Is volume trending upward over 5 days?\
       \uc0\u8594  Yes = 15 pts (sustained accumulation confirmed)\
       \uc0\u8594  No  = 0 pts\
\
    Felix's guideline: "Look for scores of 70+ with a clean chart setup.\
    That's where the best risk/reward setups live."\
\
    Score guide:\
        70\'96100 = Strong bullish money flow (potential buy setup)\
        50\'9669  = Moderate / building\
        30\'9649  = Weak / neutral\
        0\'9629   = Bearish distribution / avoid\
    """\
    score = 0\
\
    # \uc0\u9472 \u9472  Component 1: Trend (SMA50 position) \'97 0 to 50 points \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    dist_pct = row.get("Dist_SMA50_Pct", 0.0)\
    if pd.notna(dist_pct):\
        # Map dist_pct from [-10%, +10%] \uc0\u8594  [0, 50] linearly, clamp at edges\
        trend_score = 25 + (dist_pct * 2.5)          # 0% \uc0\u8594  25, +10% \u8594  50, -10% \u8594  0\
        trend_score = max(0.0, min(50.0, trend_score))\
        score += trend_score\
\
    # \uc0\u9472 \u9472  Component 2: Volume surge \'97 0 to 35 points \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    vol_ratio = row.get("Vol_Ratio", 1.0)\
    if pd.notna(vol_ratio) and vol_ratio > 1.0:\
        # Maps 1.0\'d7 \uc0\u8594  0 pts, 3.0\'d7 \u8594  35 pts (linear, capped at 35)\
        vol_score = ((vol_ratio - 1.0) / 2.0) * 35\
        vol_score = max(0.0, min(35.0, vol_score))\
        score += vol_score\
\
    # \uc0\u9472 \u9472  Component 3: Volume momentum \'97 0 or 15 points \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    vol_trend = row.get("Vol_5d_Trend", 0.0)\
    if pd.notna(vol_trend) and vol_trend == 1.0:\
        score += 15  # 5-day rising volume trend = sustained smart money activity\
\
    return int(max(0, min(100, round(score))))\
\
\
# \uc0\u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
# CHART BUILDER\
# \uc0\u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
\
\
def build_chart(df: pd.DataFrame, ticker: str, company_name: str = "") -> go.Figure:\
    """\
    Build an interactive Plotly chart matching Felix's webinar style:\
\
    Panel 1 (70% height) \'97 Candlestick chart:\
        \'95 Green candles  = up days (close > open)\
        \'95 Red candles    = down days (close < open)\
        \'95 Thick blue line = SMA50 (the trend filter)\
        \'95 Green arrows \uc0\u8593   = Bullish Accumulation signals\
        \'95 Red arrows \uc0\u8595     = Bearish Distribution signals\
\
    Panel 2 (30% height) \'97 Volume bars:\
        \'95 GREEN bar = volume > 1.5\'d7 20-day average (big money active)\
        \'95 RED bar   = normal volume (no institutional signal)\
        \'95 Orange dotted line = 20-day average volume baseline\
    """\
    title = f"\{company_name\} (\{ticker\})" if company_name else ticker\
\
    # Two-panel layout: price chart + volume bar chart\
    fig = make_subplots(\
        rows=2,\
        cols=1,\
        shared_xaxes=True,      # Lock x-axis zoom/pan between panels\
        vertical_spacing=0.04,\
        row_heights=[0.70, 0.30],\
        subplot_titles=["", "Volume"],\
    )\
\
    # \uc0\u9472 \u9472  Panel 1a: Candlestick Chart \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Green body = buying pressure (close > open)\
    # Red body   = selling pressure (close < open)\
    # Felix uses candlesticks to see the daily battle between bulls and bears.\
    fig.add_trace(\
        go.Candlestick(\
            x=df.index,\
            open=df["Open"],\
            high=df["High"],\
            low=df["Low"],\
            close=df["Close"],\
            name="Price",\
            increasing_line_color="#00c853",    # Green wick on up days\
            decreasing_line_color="#ff1744",    # Red wick on down days\
            increasing_fillcolor="#00c853",     # Solid green body\
            decreasing_fillcolor="#ff1744",     # Solid red body\
            whiskerwidth=0.4,\
        ),\
        row=1,\
        col=1,\
    )\
\
    # \uc0\u9472 \u9472  Panel 1b: SMA50 Line \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Thick, bright blue line \'97 the primary trend filter.\
    # Felix's simple rule: trade in the direction of this line.\
    # Price crossing ABOVE \uc0\u8594  potential entry signal\
    # Price crossing BELOW \uc0\u8594  exit or stand aside\
    fig.add_trace(\
        go.Scatter(\
            x=df.index,\
            y=df["SMA50"],\
            name="SMA 50",\
            line=dict(color="#2196f3", width=2.5),   # Thick blue (matches Felix's chart)\
            opacity=0.95,\
            hovertemplate="SMA50: %\{y:.2f\}p<extra></extra>",\
        ),\
        row=1,\
        col=1,\
    )\
\
    # \uc0\u9472 \u9472  Panel 1c: Bullish Accumulation Arrows (\u8593 ) \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
    # Green up-arrows placed just BELOW each bullish signal candle.\
    # This is where Felix says: "This is the footprint of smart money buying."\
    bullish_days = df[df["Bullish"] == True]\
    if not bullish_days.empty:\
        fig.add_trace(\
            go.Scatter(\
                x=bullish_days.index,\
                y=bullish_days["Low"] * 0.975,   # Position slightly below the low\
                mode="markers",\
                name="Bullish Accumulation",\
                marker=dict(\
                    symbol="arrow-up",\
                    size=13,\
                    color="#00e676",                # Bright lime green\
                    line=dict(color="#ffffff", width=1.5),\
                ),\
                hovertemplate=(\
                    "<b>\uc0\u55357 \u57314  Bullish Accumulation</b><br>"\
                    "Date: %\{x|%d %b %Y\}<br>"\
